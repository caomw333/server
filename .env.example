# ShopVibe Server 环境变量
# 复制此文件为 .env 并按需修改

PORT=3000
JWT_SECRET=your-production-secret-change-this
JWT_EXPIRES_IN=7d
DB_PATH=./data/shopvibe.db

# CORS 允许的前端地址（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# 微信小程序配置
WECHAT_APPID=wxf40962ef435cc743
WECHAT_APPSECRET=e9ccf1a5c2331db2ffbd703655a025a6
