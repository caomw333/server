# ShopVibe Server 环境变量
# 复制此文件为 .env 并按需修改

PORT=3000
JWT_SECRET=your-production-secret-change-this
JWT_EXPIRES_IN=7d
DB_PATH=./data/shopvibe.db

# CORS 允许的前端地址（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000

# 速率限制（500 请求/分钟，开发环境足够宽松）
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500

# 微信小程序配置
WECHAT_APPID=wxf40962ef435cc743
WECHAT_APPSECRET=你的AppSecret
